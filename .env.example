PORT=3000
CORS_ORIGIN=http://localhost:5173

# OpenAI / Sphinx NLP
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Actian VectorAI DB bridge (start with: docker compose up)
# Bridge talks gRPC to the VectorAI container on your behalf
ACTIAN_BRIDGE_URL=http://localhost:8001

# News sources
NEWSAPI_KEY=your-newsapi-key
ACLED_KEY=your-acled-jwt-token
ACLED_EMAIL=your-email@example.com

# Market data (primary → fallback → fallback)
POLYGON_API_KEY=your-polygon-key
ALPACA_API_KEY=your-alpaca-key
ALPACA_API_SECRET=your-alpaca-secret
FMP_API_KEY=your-fmp-key