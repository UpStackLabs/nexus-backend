PORT=3000
CORS_ORIGIN=http://localhost:5173

# OpenAI / Sphinx NLP
OPENAI_API_KEY=sk-...

# Actian VectorAI (set ACTIAN_CONNECTION_TYPE to "rest" or "pg")
ACTIAN_CONNECTION_TYPE=rest
ACTIAN_BASE_URL=https://your-actian-instance/api
ACTIAN_API_KEY=your-actian-api-key
ACTIAN_PG_HOST=your-actian-host
ACTIAN_PG_PORT=5432
ACTIAN_PG_DATABASE=shockglobe
ACTIAN_PG_USER=admin
ACTIAN_PG_PASSWORD=your-password

# News sources
NEWSAPI_KEY=your-newsapi-key
ACLED_KEY=your-acled-key
ACLED_EMAIL=you@example.com

# Market data (primary → fallback → fallback)
POLYGON_API_KEY=your-polygon-key
ALPACA_API_KEY=your-alpaca-key
ALPACA_API_SECRET=your-alpaca-secret
FMP_API_KEY=your-fmp-key
